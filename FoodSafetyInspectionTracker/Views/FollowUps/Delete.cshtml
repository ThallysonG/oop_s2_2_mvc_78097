@model FoodSafetyInspectionTracker.Models.FollowUp

@{
    ViewData["Title"] = "Delete FollowUp";
}

<h1>Delete FollowUp</h1>

<h3>Are you sure you want to delete this?</h3>

<hr />

<dl class="row">
    <dt class="col-sm-2">Inspection</dt>
    <dd class="col-sm-10">@Model.InspectionId</dd>

    <dt class="col-sm-2">Premise</dt>
    <dd class="col-sm-10">@Model.Inspection?.Premise?.Name</dd>

    <dt class="col-sm-2">Due Date</dt>
    <dd class="col-sm-10">@Model.DueDate.ToString("yyyy-MM-dd")</dd>

    <dt class="col-sm-2">Status</dt>
    <dd class="col-sm-10">@Model.Status</dd>

    <dt class="col-sm-2">Closed Date</dt>
    <dd class="col-sm-10">@(Model.ClosedDate?.ToString("yyyy-MM-dd") ?? "-")</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>