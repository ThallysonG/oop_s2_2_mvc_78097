@model IEnumerable<FoodSafetyInspectionTracker.Models.FollowUp>
@using FoodSafetyInspectionTracker.Enums

@{
    ViewData["Title"] = "Follow-Ups";
}

<h2>Follow-Ups</h2>

@if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">New Follow-Up</a>
    </p>
}

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Premises</th>
            <th>Inspection Date</th>
            <th>Due Date</th>
            <th>Status</th>
            <th>Closed Date</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var overdue = item.Status == FollowUpStatus.Open && item.DueDate < DateTime.Today;

            <tr class="@(overdue ? "table-danger" : "")">
                <td>@item.Inspection?.Premises?.Name</td>
                <td>@item.Inspection?.InspectionDate.ToShortDateString()</td>
                <td>@item.DueDate.ToShortDateString()</td>
                <td>@item.Status</td>
                <td>@(item.ClosedDate?.ToShortDateString() ?? "-")</td>
                <td>
                    @if ((User.IsInRole("Admin") || User.IsInRole("Inspector")) && item.Status == FollowUpStatus.Open)
                    {
                        <a asp-action="Close" asp-route-id="@item.Id" class="btn btn-sm btn-success">Close</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>