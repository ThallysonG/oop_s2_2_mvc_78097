@model FoodSafetyInspectionTracker.Models.Inspection

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete Inspection</h1>

<h3>Are you sure you want to delete this?</h3>

<hr />

<dl class="row">
    <dt class="col-sm-2">Premise</dt>
    <dd class="col-sm-10">@Model.Premise?.Name</dd>

    <dt class="col-sm-2">Date</dt>
    <dd class="col-sm-10">@Model.InspectionDate.ToString("yyyy-MM-dd")</dd>

    <dt class="col-sm-2">Score</dt>
    <dd class="col-sm-10">@Model.Score</dd>

    <dt class="col-sm-2">Outcome</dt>
    <dd class="col-sm-10">@Model.Outcome</dd>

    <dt class="col-sm-2">Notes</dt>
    <dd class="col-sm-10">@Model.Notes</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>