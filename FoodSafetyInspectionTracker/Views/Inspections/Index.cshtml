@model IEnumerable<FoodSafetyInspectionTracker.Models.Inspection>

@{
    ViewData["Title"] = "Inspections";
}

<h1>Inspections</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Inspection</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Premise</th>
            <th>Date</th>
            <th>Score</th>
            <th>Outcome</th>
            <th>Notes</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Premise?.Name</td>
                <td>@item.InspectionDate.ToString("yyyy-MM-dd")</td>
                <td>@item.Score</td>
                <td>@item.Outcome</td>
                <td>@item.Notes</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>