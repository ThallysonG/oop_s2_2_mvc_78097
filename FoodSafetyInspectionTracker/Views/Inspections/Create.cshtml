@model FoodSafetyInspectionTracker.ViewModels.InspectionCreateViewModel
@using FoodSafetyInspectionTracker.Models
@using FoodSafetyInspectionTracker.Enums

@{
    ViewData["Title"] = "Create Inspection";
    var premises = ViewBag.Premises as List<Premises>;
}

<h2>Create Inspection</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="PremisesId" class="form-label"></label>
        <select asp-for="PremisesId" class="form-select">
            <option value="">Select premises</option>
            @foreach (var item in premises!)
            {
                <option value="@item.Id">@item.Name (@item.Town)</option>
            }
        </select>
        <span asp-validation-for="PremisesId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="InspectionDate" class="form-label"></label>
        <input asp-for="InspectionDate" class="form-control" />
        <span asp-validation-for="InspectionDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Score" class="form-label"></label>
        <input asp-for="Score" class="form-control" />
        <span asp-validation-for="Score" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Outcome" class="form-label"></label>
        <select asp-for="Outcome" class="form-select" asp-items="Html.GetEnumSelectList<InspectionOutcome>()"></select>
        <span asp-validation-for="Outcome" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}